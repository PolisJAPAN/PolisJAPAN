# PolisJAPAN ローカル開発用シークレットの雛形
# このファイルを Server/web/.env にコピーし、実値を設定する（.env はgitignore対象・コミット禁止）
# docker-compose が web コンテナに env_file として読み込む

# --- AI連携 ---
OPENAI_API_KEY=
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true

# --- AWS（localhost環境でS3/DynamoDBにアクセスする場合のみ） ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-3

# --- アプリ設定 ---
ENCRYPT_SALT=
BATCH_ACCESS_KEY=
USER_ACCESS_KEY=
# カンマ区切りのCIDRリスト
ADMIN_ALLOW_IPS=127.0.0.1,172.16.0.0/12

# --- ローカルDB（docker-compose.yml の MYSQL_PASSWORD と一致させる） ---
DB_PASSWORD=app_password

# --- pol.is ログイン（batch-create をローカル実行する場合のみ） ---
POLIS_LOGIN_USER=
POLIS_LOGIN_PASSWORD=
